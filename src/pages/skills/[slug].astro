---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { Marked, type Tokens } from 'marked';
import { listPublicSkills } from '../../lib/skills';
import { fetchOgMeta } from '../../lib/og-meta';
import InstallInstructions from '../../components/InstallInstructions.astro';

export async function getStaticPaths() {
  return listPublicSkills().map((skill) => ({
    params: { slug: skill.name },
    props: { skill },
  }));
}

function slugify(text: string): string {
  return text
    .toLowerCase()
    .trim()
    .replace(/[^\w\s-]/g, '')
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-');
}

const { skill } = Astro.props;

// Resolve related skill names → SkillFile objects. Silently drop unknown
// names (lint flags them at build time).
const allSkills = listPublicSkills();
const relatedSkills = (skill.wrapper.related ?? [])
  .map((name) => allSkills.find((s) => s.name === name))
  .filter((s): s is typeof allSkills[number] => Boolean(s) && s!.name !== skill.name);

// Build a fresh Marked instance per-page with a renderer that adds heading
// IDs, so Starlight's TOC anchors actually link somewhere.
const md = new Marked({
  renderer: {
    heading(token) {
      const text = this.parser.parseInline(token.tokens);
      const slug = slugify(this.parser.parseInline(token.tokens, this.parser.textRenderer));
      return `<h${token.depth} id="${slug}">${text}</h${token.depth}>\n`;
    },
  },
});

// Tokenise once to extract H2/H3 headings for the right-side outline.
const headings = md
  .lexer(skill.wrapperBody)
  .filter((t): t is Tokens.Heading =>
    t.type === 'heading' && (t.depth === 2 || t.depth === 3))
  .map((t) => ({ depth: t.depth, slug: slugify(t.text), text: t.text }));

if (relatedSkills.length > 0) {
  headings.push({ depth: 2, slug: 'related-skills', text: 'Related skills' });
}

const wrapperBodyHtml = await md.parse(skill.wrapperBody);
const FENCE = '-'.repeat(3);
const frontmatterLines = Object.entries(skill.skillFrontmatter)
  .map(([k, v]) => `${k}: ${typeof v === 'string' ? JSON.stringify(v) : String(v)}`)
  .join('\n');
const rawSkillFile = `${FENCE}\n${frontmatterLines}\n${FENCE}\n\n${skill.skillBody}\n`;

// Pull OG meta from the source article, if one is set. Reuses its hero
// image so social shares of this skill page get the article's visual.
const og = skill.wrapper.source ? await fetchOgMeta(skill.wrapper.source.url) : undefined;

type HeadTag = { tag: 'meta'; attrs?: Record<string, string | boolean | undefined> };
const head: HeadTag[] = [];
if (og?.image) {
  head.push({ tag: 'meta', attrs: { property: 'og:image', content: og.image } });
  head.push({ tag: 'meta', attrs: { name: 'twitter:card', content: 'summary_large_image' } });
  head.push({ tag: 'meta', attrs: { name: 'twitter:image', content: og.image } });
  if (og.imageWidth) head.push({ tag: 'meta', attrs: { property: 'og:image:width', content: og.imageWidth } });
  if (og.imageHeight) head.push({ tag: 'meta', attrs: { property: 'og:image:height', content: og.imageHeight } });
  if (og.imageAlt) head.push({ tag: 'meta', attrs: { property: 'og:image:alt', content: og.imageAlt } });
}
if (og?.publishedTime) head.push({ tag: 'meta', attrs: { property: 'article:published_time', content: og.publishedTime } });
if (og?.modifiedTime) head.push({ tag: 'meta', attrs: { property: 'article:modified_time', content: og.modifiedTime } });
if (og?.author) head.push({ tag: 'meta', attrs: { property: 'article:author', content: og.author } });
// twitter:title and twitter:description default to og:title/og:description on most clients;
// add explicitly anyway so X/LinkedIn previews are guaranteed to use them.
head.push({ tag: 'meta', attrs: { name: 'twitter:title', content: skill.wrapper.title } });
head.push({ tag: 'meta', attrs: { name: 'twitter:description', content: skill.wrapper.summary } });
if (skill.lastUpdated && !og?.modifiedTime) {
  head.push({ tag: 'meta', attrs: { property: 'article:modified_time', content: `${skill.lastUpdated}T00:00:00Z` } });
}
---

<StarlightPage frontmatter={{ title: skill.wrapper.title, description: skill.wrapper.summary, head }} headings={headings}>
  <p>
    <em>{skill.wrapper.summary}</em>
    {skill.wrapper.source && (
      <em class="source-cite"> Adapted from <a href={skill.wrapper.source.url} target="_blank" rel="noopener">{skill.wrapper.source.title}</a>.</em>
    )}
  </p>

  {skill.wrapper.input && skill.wrapper.output && (
    <dl class="io-tile not-content">
      <div class="io-row">
        <dt>Input</dt>
        <dd>{skill.wrapper.input}</dd>
      </div>
      <div class="io-row">
        <dt>Output</dt>
        <dd>{skill.wrapper.output}</dd>
      </div>
    </dl>
  )}

  <InstallInstructions
    name={skill.name}
    copyText={rawSkillFile}
    githubUrl={skill.githubUrl}
    rawUrl={skill.rawUrl}
    lastUpdated={skill.lastUpdated}
  />

  <div class="wrapper-body" set:html={wrapperBodyHtml} />

  {relatedSkills.length > 0 && (
    <section class="related not-content" aria-labelledby="related-skills">
      <h2 id="related-skills">Related skills</h2>
      <ul class="related-list">
        {relatedSkills.map((r) => (
          <li class="related-card">
            <a href={`/skills/${r.name}/`}>
              <h3>{r.wrapper.cardTitle ?? r.wrapper.title}</h3>
              <p>{r.wrapper.hook ?? r.wrapper.summary}</p>
              <code>{r.name}</code>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}
</StarlightPage>

<style>
  .source-cite {
    color: var(--sl-color-gray-3);
  }

  .io-tile {
    display: grid;
    gap: 0.5rem;
    margin-block: 1rem 1.5rem;
    padding: 0.85rem 1rem;
    border-left: 3px solid var(--sl-color-accent);
    background: var(--sl-color-gray-6);
    border-radius: 0 0.375rem 0.375rem 0;
    box-sizing: border-box;
    min-width: 0;
    max-width: 100%;
  }
  @media (max-width: 30rem) {
    .io-tile {
      padding: 0.75rem 0.85rem 0.75rem 0.7rem;
      margin-inline: -0.25rem;
    }
  }
  .io-row {
    display: grid;
    grid-template-columns: 5rem 1fr;
    gap: 0.75rem;
    align-items: baseline;
  }
  .io-row dt {
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--sl-color-accent-high);
    margin: 0;
  }
  .io-row dd {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.45;
  }
  @media (max-width: 30rem) {
    .io-row {
      grid-template-columns: 1fr;
      gap: 0.1rem;
    }
  }

  /* Same overflow-fix as in InstallInstructions, for fenced code blocks
     rendered into the wrapper body (e.g. the ## Example invocation block). */
  .wrapper-body pre {
    overflow-x: auto;
    max-width: 100%;
    white-space: pre;
  }

  .related {
    margin-top: 2.5rem;
  }
  .related h2 {
    margin-bottom: 0.75rem;
  }
  .related-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(min(18rem, 100%), 1fr));
  }
  .related-card {
    position: relative;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background: var(--sl-color-gray-6);
    overflow: hidden;
    transition: border-color 0.15s, background-color 0.15s;
  }
  .related-card::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background: var(--sl-color-accent);
  }
  .related-card:hover {
    border-color: var(--sl-color-accent);
    background: color-mix(in srgb, var(--sl-color-gray-6) 85%, var(--sl-color-gray-5));
  }
  .related-card a {
    display: block;
    padding: 0.85rem 1rem;
    color: inherit;
    text-decoration: none;
  }
  .related-card h3 {
    margin: 0 0 0.3rem;
    font-size: 1rem;
  }
  .related-card p {
    margin: 0 0 0.5rem;
    color: var(--sl-color-gray-2);
    font-size: 0.9rem;
  }
  .related-card code {
    font-size: 0.75rem;
    color: var(--sl-color-gray-3);
  }
</style>
