---
import { listPublicSkills } from '../lib/skills';
import { fetchOgMeta } from '../lib/og-meta';

interface Props {
  /** If true, only show skills with `featured: true`. If false/undefined, show all. */
  featured?: boolean;
  /** If true, hide skills that are steps of a workshop — they belong under their
   * workshop, not in the flat skills list. */
  independentOnly?: boolean;
}
const { featured, independentOnly } = Astro.props;

const all = listPublicSkills();
let skills = featured ? all.filter((s) => s.wrapper.featured) : all;
if (independentOnly) skills = skills.filter((s) => !s.wrapper.workshop);

// Resolve OG thumbnails in parallel; failures fall back to no image.
const thumbs = await Promise.all(
  skills.map(async (s) => {
    if (!s.wrapper.source) return undefined;
    const og = await fetchOgMeta(s.wrapper.source.url);
    return og?.image;
  }),
);
---

{skills.length === 0 ? (
  featured ? null : (
    <p><em>No public skills yet. Add one at <code>src/content/skills/asb-&lt;name&gt;.mdx</code> with a matching <code>.claude/skills/asb-&lt;name&gt;/SKILL.md</code>.</em></p>
  )
) : (
  <ul class="skills-list not-content">
    {skills.map((s, i) => (
      <li class="skill-card">
        <a href={`/skills/${s.name}/`}>
          {thumbs[i] && (
            <img
              class="skill-thumb"
              src={thumbs[i]}
              alt=""
              loading="lazy"
              decoding="async"
            />
          )}
          <div class="skill-text">
            <h3>{s.wrapper.cardTitle ?? s.wrapper.title}</h3>
            <p class="hook">{s.wrapper.hook ?? s.wrapper.summary}</p>
            <code>{s.name}</code>
          </div>
        </a>
      </li>
    ))}
  </ul>
)}

<style>
  .skills-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(min(20rem, 100%), 1fr));
  }
  .skill-card {
    position: relative;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background: var(--sl-color-gray-6);
    transition: border-color 0.15s, background-color 0.15s;
    overflow: hidden;
  }
  /* Thin accent stripe along the top edge of every card. */
  .skill-card::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background: var(--sl-color-accent);
    z-index: 1;
  }
  .skill-card:hover {
    border-color: var(--sl-color-accent);
    background: color-mix(in srgb, var(--sl-color-gray-6) 85%, var(--sl-color-gray-5));
  }
  .skill-card a {
    display: flex;
    gap: 1rem;
    padding: 1rem 1.25rem;
    color: inherit;
    text-decoration: none;
    align-items: flex-start;
  }
  .skill-text {
    flex: 1;
    min-width: 0;
  }
  .skill-card h3 {
    margin: 0 0 0.4rem;
    font-size: 1.15rem;
  }
  .skill-card .hook {
    margin: 0 0 0.75rem;
    color: var(--sl-color-gray-2);
    font-size: 0.95rem;
  }
  .skill-card code {
    font-size: 0.8rem;
    color: var(--sl-color-gray-3);
  }
  .skill-thumb {
    flex: 0 0 auto;
    width: 5rem;
    height: 5rem;
    object-fit: cover;
    border-radius: 0.375rem;
    border: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-gray-5);
    display: block;
    order: 2; /* place to the right of the text */
  }
  @media (max-width: 24rem) {
    .skill-thumb {
      width: 4rem;
      height: 4rem;
    }
  }
</style>
