---
/**
 * Curator byline shown on the home page.
 *
 * To replace the avatar image: drop a new square JPEG/PNG into
 * `src/assets/jason-cohen.jpg` (same filename) and rebuild. Astro will
 * regenerate the WebP/AVIF/responsive variants automatically.
 */
import { Image } from 'astro:assets';
import jasonPhoto from '../assets/jason-cohen.jpg';
---

<aside class="curator">
  <a class="avatar-link" href="https://asmartbear.com/jason-cohen/" target="_blank" rel="noopener" aria-label="About Jason Cohen">
    <Image src={jasonPhoto} alt="Jason Cohen" width={112} height={112} class="avatar" loading="eager" />
  </a>
  <p class="byline">
    by <a href="https://asmartbear.com/jason-cohen/" target="_blank" rel="noopener"><strong>Jason Cohen</strong></a>, founder of two Unicorns (WP Engine, Smart Bear).
  </p>
</aside>

<style>
  .curator {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin: 0.5rem 0 1rem;
  }
  .avatar-link {
    flex-shrink: 0;
    display: block;
    line-height: 0;
    border-radius: 50%;
    transition: transform 0.15s ease;
  }
  .avatar-link:hover {
    transform: scale(1.05);
  }
  .avatar {
    display: block;
    width: 56px;
    height: 56px;
    border-radius: 50%;
  }
  .byline {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.45;
    color: var(--sl-color-gray-2);
  }
  .byline a {
    color: inherit;
    text-decoration: none;
  }
  .byline a:hover strong {
    color: var(--sl-color-accent-high);
  }
  .byline strong {
    color: var(--sl-color-white);
    font-weight: 700;
  }
  @media (max-width: 30rem) {
    .curator {
      gap: 0.7rem;
    }
    .avatar {
      width: 48px;
      height: 48px;
    }
  }
</style>
