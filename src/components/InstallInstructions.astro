---
import { URLS, INSTALL, githubRawUrl, githubBlobUrl } from '../lib/site';
import CopyButton from './CopyButton.astro';

interface Props {
  /** Skill name, e.g. "asb-pricing-ladder". If omitted, generic placeholder is used. */
  name?: string;
  /** Full text of the SKILL.md file (with frontmatter) for the Copy button. */
  copyText?: string;
  /** GitHub blob URL for "View source on GitHub". Defaults to computed from name. */
  githubUrl?: string;
  /** GitHub raw URL for "Raw file". Defaults to computed from name. */
  rawUrl?: string;
  /** ISO date (YYYY-MM-DD) of the last git commit touching the skill. Renders a small footer line; omitted if undefined. */
  lastUpdated?: string;
}
const { name, copyText, githubUrl, rawUrl, lastUpdated } = Astro.props;
const skillName = name ?? 'asb-skill-name';
const rawSkillUrl = rawUrl ?? githubRawUrl(`.claude/skills/${skillName}/SKILL.md`);
const blobSkillUrl = githubUrl ?? githubBlobUrl(`.claude/skills/${skillName}/SKILL.md`);
---

<aside class="install-box">
  <h3>Installing <code>{skillName}</code></h3>

  <div class="install-cli">
    <pre><code>{INSTALL.cliAddAll}</code></pre>
    <CopyButton text={INSTALL.cliAddAll} label="Copy command" />
  </div>
  <p class="install-hint">
    Installs every skill on this site into Claude Code, Codex, Cursor, and
    dozens of other agents — recommended, since the skills work together.
    (Append <code>--skill {skillName}</code> to install only this one.)
    Later, <code>{INSTALL.cliUpdate}</code> picks up improvements.
    Or skip the tooling and grab the file itself:
  </p>

  <div class="install-actions">
    {copyText && <CopyButton text={copyText} label="Copy SKILL.md" />}
    <a href={blobSkillUrl} target="_blank" rel="noopener">View source on GitHub →</a>
    <a href={rawSkillUrl} target="_blank" rel="noopener">Raw file →</a>
  </div>

  <p class="install-hint">
    Save into <code>~/.claude/skills/{skillName}/SKILL.md</code>, then restart
    Claude Code (or run <code>/context</code>) to pick up the new skill.
  </p>

  <p class="install-all">
    <a href={URLS.allSkillsZip} download>↓ Or download <strong>all skills</strong> as one ZIP</a>
    — the easiest way to get this skill together with everything it works alongside.
  </p>

  {lastUpdated && (
    <p class="install-stamp">Last updated <time datetime={lastUpdated}>{lastUpdated}</time></p>
  )}
</aside>

<style>
  .install-box {
    border-left: 4px solid var(--sl-color-accent);
    background: var(--sl-color-gray-6);
    padding: 1rem 1.25rem;
    border-radius: 0 0.5rem 0.5rem 0;
    margin-block: 1.5rem;
    /* Allow flex/grid children (and `<pre>` snippets) to shrink below
       their intrinsic content width instead of forcing the page wider. */
    min-width: 0;
    max-width: 100%;
    box-sizing: border-box;
  }
  @media (max-width: 30rem) {
    .install-box {
      padding: 0.85rem 0.85rem 0.85rem 0.75rem;
    }
  }
  .install-box pre {
    overflow-x: auto;
    max-width: 100%;
    /* Preserve original line breaks but let the box's overflow handle width. */
    white-space: pre;
  }
  .install-box h3 {
    margin-top: 0;
  }

  .install-cli {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-items: center;
    margin-block: 0.6rem 0.35rem;
  }
  .install-cli pre {
    margin: 0;
    padding: 0.4rem 0.7rem;
    border-radius: 0.375rem;
    background: var(--sl-color-black);
    border: 1px solid var(--sl-color-gray-5);
    font-size: 0.85rem;
  }

  .install-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
    margin-block: 0.5rem 0.75rem;
  }

  .install-hint {
    font-size: 0.9rem;
    opacity: 0.85;
    margin-block: 0.5rem;
  }

  .install-all {
    margin-block: 0.85rem 0.25rem;
    padding-top: 0.75rem;
    border-top: 1px solid color-mix(in srgb, var(--sl-color-accent) 30%, transparent);
    font-size: 0.92rem;
  }
  .install-all a {
    font-weight: 600;
  }

  .install-stamp {
    margin: 0.75rem 0 0;
    font-size: 0.8rem;
    color: var(--sl-color-gray-3);
  }
</style>
